# Server Configuration
PORT=3000
NODE_ENV=development

# API Security
ACTIVITY_TOKEN=your_secure_token_here
ACTIVITY_RELAY_API_KEY=your_relay_api_key_here

# Discord Bot Configuration
DISCORD_PRODUCTION_TOKEN=your_production_discord_bot_token
DISCORD_DEVELOPMENT_TOKEN=your_development_discord_bot_token

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/maylog
# If using MongoDB with SSL certificate
# MONGO_CERT_PATH=certificates/mongodb-maylog.crt

# Redis Configuration
REDIS_HOST=your_redis_host_ip
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# External API Keys
ROBLOX_COOKIE=your_roblox_cookie_here
ROVER_API_KEY=your_rover_api_key_here

# Monitoring & Error Tracking
SENTRY_DSN=your_sentry_dsn_here

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com