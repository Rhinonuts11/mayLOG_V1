# Railway Environment Variables for mayLOG Activity API

# Required - API Security Token
ACTIVITY_TOKEN=your_secure_token_here

# Optional - Additional API key for compatibility
ACTIVITY_RELAY_API_KEY=your_relay_api_key_here

# Server Configuration (Railway will set PORT automatically)
NODE_ENV=production

# CORS Settings (optional)
ALLOWED_ORIGINS=https://yourdomain.com,https://anotherdomain.com

# Railway will automatically provide PORT, but you can override if needed
# PORT=3000